<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="10dp"
    android:paddingEnd="8dp">

    <ImageView
        android:id="@+id/imagePlace"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_dialog_input"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textPlaceName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textPlaceCategoryDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/cabinet_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/buttonAddPlace"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_suggested_place_add_btn"
        android:contentDescription="@string/add_location_title"
        android:padding="8dp"
        android:src="@drawable/ic_add"
        app:tint="@color/hotel_gold" />
</LinearLayout>
