<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/hotel_content_card_bg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/trip_request_summary_title"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/trip_detail_booking_details"
        android:textColor="@color/cabinet_text_secondary"
        android:textSize="12sp" />
    <TextView
        android:id="@+id/textDialogTripName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/trip_detail_select_date"
        android:textColor="@color/cabinet_text_secondary"
        android:textSize="12sp" />
    <TextView
        android:id="@+id/textDialogDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/trip_detail_participants"
        android:textColor="@color/cabinet_text_secondary"
        android:textSize="12sp" />
    <TextView
        android:id="@+id/textDialogParticipants"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/trip_detail_price_per_person"
        android:textColor="@color/cabinet_text_secondary"
        android:textSize="12sp" />
    <TextView
        android:id="@+id/textDialogPricePerPerson"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/light_grey"
        android:layout_marginVertical="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/trip_detail_total_price"
        android:textColor="@color/cabinet_text_secondary"
        android:textSize="12sp" />
    <TextView
        android:id="@+id/textDialogTotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/hotel_gold"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />
</LinearLayout>
