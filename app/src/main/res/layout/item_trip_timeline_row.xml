<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingBottom="10dp">

    <!-- Time label -->
    <TextView
        android:id="@+id/textTime"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="07:00"
        android:paddingTop="7dp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:textSize="14sp" />

    <!-- Timeline: vertical line + dot (height matches card) -->
    <LinearLayout
        android:layout_width="24dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:minHeight="56dp">

        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            android:background="@drawable/timeline_dot" />

        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:layout_gravity="center_horizontal"
            android:background="@color/hotel_gold" />

    </LinearLayout>

    <!-- Activity card -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_weight="1"
        android:background="@drawable/bg_trip_info_card"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/textActivityTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textActivityDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/cabinet_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
