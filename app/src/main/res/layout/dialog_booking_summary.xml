<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/hotel_content_card_bg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/booking_summary_title"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/booking_summary_hotel"
        android:textColor="@color/cabinet_text_secondary"
        android:textSize="12sp" />
    <TextView
        android:id="@+id/dialogSummaryHotelName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/cabinet_check_in"
        android:textColor="@color/cabinet_text_secondary"
        android:textSize="12sp" />
    <TextView
        android:id="@+id/dialogSummaryCheckIn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/cabinet_check_out"
        android:textColor="@color/cabinet_text_secondary"
        android:textSize="12sp" />
    <TextView
        android:id="@+id/dialogSummaryCheckOut"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/cabinet_guests"
        android:textColor="@color/cabinet_text_secondary"
        android:textSize="12sp" />
    <TextView
        android:id="@+id/dialogSummaryGuests"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/cabinet_room_type"
        android:textColor="@color/cabinet_text_secondary"
        android:textSize="12sp" />
    <TextView
        android:id="@+id/dialogSummaryRoomType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/cabinet_total_price"
        android:textColor="@color/cabinet_text_secondary"
        android:textSize="12sp" />
    <TextView
        android:id="@+id/dialogSummaryTotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/hotel_gold"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/dialogButtonSave"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:backgroundTint="@color/hotel_gold"
        android:text="@string/booking_save"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>
